# Database type: "sqlite" or "postgresql"
DB_ASSISTANT_DB_TYPE=sqlite

# SQLite file path (used when DB_TYPE=sqlite)
DB_ASSISTANT_DB_PATH=database.db

# PostgreSQL connection URL (used when DB_TYPE=postgresql)
# DB_ASSISTANT_DB_URL=postgresql://user:password@localhost:5432/mydb

# Query safety limits
DB_ASSISTANT_QUERY_TIMEOUT=30.0
DB_ASSISTANT_MAX_ROWS=1000
